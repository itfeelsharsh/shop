# Client-side Firebase Configuration (used by React)
REACT_APP_FIREBASE_API_KEY="your_firebase_api_key"
REACT_APP_FIREBASE_AUTH_DOMAIN="your_project_id.firebaseapp.com"
REACT_APP_FIREBASE_PROJECT_ID="your_project_id"
REACT_APP_FIREBASE_STORAGE_BUCKET="your_project_id.firebasestorage.app"
REACT_APP_FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id"
REACT_APP_FIREBASE_APP_ID="your_app_id"
REACT_APP_FIREBASE_VAPID_KEY="your_firebase_vapid_key"

# Backend Firebase Configuration (used by Cloudflare Pages/Functions)
FIREBASE_API_KEY="your_firebase_api_key"
FIREBASE_PROJECT_ID="your_project_id"

# reCAPTCHA v3 Configuration (Public site key)
REACT_APP_RECAPTCHA_SITE_KEY="your_recaptcha_site_key"

# Stripe Payment Gateway Configuration (Private secrets)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Resend Transactional Email Configuration (Private API key)
RESEND_API_KEY="re_..."
